# Copy to deploy/.env on the EC2 instance and fill in the RDS values.
# Get DATABASE_URL from: terraform output -raw database_url
DATABASE_URL=postgresql://echotype:PASSWORD@ECHOTYPE-DB-ENDPOINT:5432/echotype
DEMO_USER_ID=demo-user
API_PORT=3001
# Public origin used for CORS. In the cloud this is the CloudFront HTTPS URL
# (CI reads it from SSM /echotype/WEB_ORIGIN automatically).
WEB_ORIGIN=https://CLOUDFRONT_DOMAIN
