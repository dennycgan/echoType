# Copy to terraform.tfvars and fill in real values. terraform.tfvars is gitignored.

# Your home public IP as a /32 CIDR. Find it with: curl -s https://checkip.amazonaws.com
my_ip_cidr = "1.2.3.4/32"

# RDS master password (>= 16 chars recommended, no '/', '@', '"', or spaces).
db_password = "change-me-to-a-strong-password"

# Optional overrides:
# region            = "ap-southeast-2"
# instance_type     = "t4g.micro"
# db_instance_class = "db.t4g.micro"
# public_key_path   = "~/.ssh/echotype_ec2.pub"

# Sentry (required on first apply after Ops Phase 1 — from Sentry project settings)
# sentry_dsn_web = "https://<key>@<org>.ingest.sentry.io/<project-id>"
# sentry_dsn_api = "https://<key>@<org>.ingest.sentry.io/<project-id>"

# Google sign-in Phase 1 (Cognito Google IdP — secret stays in Terraform/Cognito only, NOT EC2/SSM)
# cognito_domain_prefix = "echotype-ink"
# After: terraform output -raw google_oauth_redirect_uri  → use in GCP OAuth client
# google_oauth_client_id     = "<from GCP>"
# google_oauth_client_secret = "<from GCP>"
